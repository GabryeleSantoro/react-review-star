{
	"name": "react-review-star",
	"description": "A lightweight, accessible star rating component for React",
	"version": "1.0.0",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/GabryeleSantoro/react-review-star.git"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "tsup",
		"playground": "npm run build && npm install --prefix playground && npm run dev --prefix playground"
	},
	"keywords": [
		"react",
		"star",
		"rating",
		"component"
	],
	"author": "gabryele",
	"license": "MIT",
	"peerDependencies": {
		"react": ">=17.0.0"
	},
	"overrides": {
		"picomatch": "^4.0.4"
	},
	"devDependencies": {
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^13.1.5",
		"@types/react": "^18.3.11",
		"conventional-changelog-conventionalcommits": "^9.3.1",
		"react": "^18.3.1",
		"semantic-release": "^25.0.3",
		"tsup": "^8.3.0",
		"typescript": "^5.6.3"
	}
